# ============================================================================
# KJ BridgeDeck — Environment Template
# Copy this to .env and fill in real values. Never commit .env.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://dhzpwobfihrprlcxqjbq.supabase.co
SUPABASE_SERVICE_KEY=paste_service_role_key_here
SUPABASE_ANON_KEY=paste_anon_key_here

# --- Brain ------------------------------------------------------------------
BRAIN_API_URL=https://jim-brain-production.up.railway.app
BRAIN_KEY=jim-brain-kje-2026-kingjames

# --- Anthropic (watcher summarizer + Bridge chat) ---------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Whisper STT for Bridge voice) ----------------------------------
OPENAI_API_KEY=sk-...

# --- BridgeDeck internal auth -----------------------------------------------
BRIDGEDECK_ADMIN_KEY=bridgedeck-kj-2026-kingjames

# --- Watcher local HTTP API (Bridge-C → Bridge-B) ---------------------------
WATCHER_LOCAL_API=http://localhost:7171
WATCHER_HOST=http://localhost:7171
WATCHER_LOCAL_PORT=7171

# --- Machine identity (unique per computer) ---------------------------------
MACHINE_ID=jim-windows-main

# --- Claude Code session paths ---------------------------------------------
# Watcher reads JSONL transcripts from both. Comment out one to disable.
CLAUDE_CODE_WINDOWS_PATH=C:\Users\Jim\.claude
CLAUDE_CODE_WSL_PATH=\\wsl$\Ubuntu\home\jim\.claude

# --- Optional: Notifications -----------------------------------------------
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Optional: Voice -------------------------------------------------------
# Set after running install/install_piper.ps1
PIPER_BINARY_PATH=
PIPER_MODEL_PATH=
ELEVENLABS_API_KEY=

# --- Deployment URLs (filled after deploy) ---------------------------------
API_PUBLIC_URL=https://kj-bridgedeck-api.onrender.com
UI_PUBLIC_URL=https://bridgedeck.pages.dev
